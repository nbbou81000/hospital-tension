{% comment %}
  Hospital Tension Dashboard — full.liquid (detailed view)
  Settings expected (settings.yml): lang ("fr"/"en"), country ("fr"/"us"), fr_region, us_state
  Data expected: data.json generated by fetch-data.js -> keys "us" and "fr"
{% endcomment %}

{% comment %} --- Translation dictionary --- {% endcomment %}
{% if lang == "en" %}
  {% assign t_title_us = "Hospital tension — " %}
  {% assign t_week_ending = "Week ending" %}
  {% assign t_beds_occ = "Inpatient beds occupied" %}
  {% assign t_level_low = "low" %}
  {% assign t_level_moderate = "moderate" %}
  {% assign t_level_high = "high" %}
  {% assign t_level_word = "level" %}
  {% assign t_vs_last_week = "vs last week" %}
  {% assign t_scale = "0% · threshold 70% · threshold 85% · 100%" %}
  {% assign t_icu = "Intensive care (ICU)" %}
  {% assign t_adult = "Adult" %}
  {% assign t_ped = "Pediatric" %}
  {% assign t_new_adm = "New admissions this week (rate / 100,000 pop.)" %}
  {% assign t_flu = "Flu" %}
  {% assign t_trend_beds = "Bed occupancy trend, inpatient vs ICU (last 8 weeks)" %}
  {% assign t_inpatient = "Inpatient" %}
  {% assign t_coverage = "Reporting coverage" %}
  {% assign t_hospitals = "hospitals reported this week" %}
  {% assign t_source_us = "Source: CDC NHSN, Weekly Hospital Respiratory Data · data.cdc.gov" %}
  {% assign t_ed_visits = "ED visits share by pathogen (NSSP, smoothed)" %}
  {% assign t_ed_note = "share of all ED visits attributed to each pathogen" %}
  {% assign t_source_nssp = "Source: CDC NSSP, ED Visit Trajectories" %}

  {% assign t_title_fr = "Emergency room activity — " %}
  {% assign t_trend_label = "trend" %}
  {% assign t_trend_up = "rising" %}
  {% assign t_trend_stable = "stable" %}
  {% assign t_trend_down = "falling" %}
  {% assign t_trauma = "ED visits for trauma / 100,000 pop. (main activity indicator)" %}
  {% assign t_ira = "ED visits for acute respiratory infection / 100,000 pop." %}
  {% assign t_trend_8w = "Trend, trauma vs respiratory (last 8 weeks)" %}
  {% assign t_trauma_line = "Trauma" %}
  {% assign t_ira_line = "Respiratory" %}
  {% assign t_by_age = "Trauma rate by age group / 100,000 pop." %}
  {% assign t_age_0_14 = "0–14 yrs" %}
  {% assign t_age_15_64 = "15–64 yrs" %}
  {% assign t_age_65 = "65+ yrs" %}
  {% assign t_other_path = "Other conditions, ED visit rate / 100,000 pop." %}
  {% assign t_path_covid = "COVID-19" %}
  {% assign t_path_gastro = "Gastroenteritis" %}
  {% assign t_path_bronchite = "Bronchitis" %}
  {% assign t_path_pneumopathie = "Pneumonia" %}
  {% assign t_path_orl = "ENT conditions" %}
  {% assign t_path_asthme = "Asthma" %}
  {% assign t_path_allergie = "Allergy" %}
  {% assign t_disclaimer = "Approximation: no open-data bed-occupancy rate exists in France. This indicator is based on emergency room visits (OSCOUR / SurSaUD network, Santé publique France, Odissé portal), not on actual bed capacity." %}
  {% assign t_source_fr = "Source: Santé publique France, Odissé open data portal (SurSaUD / OSCOUR network)" %}
{% else %}
  {% assign t_title_us = "Tension hospitalière — " %}
  {% assign t_week_ending = "Semaine se terminant le" %}
  {% assign t_beds_occ = "Lits hospitalisation occupés" %}
  {% assign t_level_low = "faible" %}
  {% assign t_level_moderate = "modérée" %}
  {% assign t_level_high = "élevée" %}
  {% assign t_level_word = "niveau" %}
  {% assign t_vs_last_week = "vs semaine précédente" %}
  {% assign t_scale = "0% ─ seuil 70% ─ seuil 85% ─ 100%" %}
  {% assign t_icu = "Réanimation (ICU)" %}
  {% assign t_adult = "Adultes" %}
  {% assign t_ped = "Pédiatrique" %}
  {% assign t_new_adm = "Nouvelles admissions cette semaine (taux / 100 000 hab.)" %}
  {% assign t_flu = "Grippe" %}
  {% assign t_trend_beds = "Évolution occupation lits, hospitalisation vs réanimation (8 semaines)" %}
  {% assign t_inpatient = "Hospitalisation" %}
  {% assign t_coverage = "Couverture du reporting" %}
  {% assign t_hospitals = "hôpitaux ont transmis leurs données cette semaine" %}
  {% assign t_source_us = "Source : CDC NHSN, Weekly Hospital Respiratory Data · data.cdc.gov" %}
  {% assign t_ed_visits = "Part des passages aux urgences par pathogène (NSSP, lissé)" %}
  {% assign t_ed_note = "part de l'ensemble des passages aux urgences attribuée à chaque pathogène" %}
  {% assign t_source_nssp = "Source : CDC NSSP, ED Visit Trajectories" %}

  {% assign t_title_fr = "Activité des urgences — " %}
  {% assign t_trend_label = "tendance" %}
  {% assign t_trend_up = "hausse" %}
  {% assign t_trend_stable = "stable" %}
  {% assign t_trend_down = "baisse" %}
  {% assign t_trauma = "Passages aux urgences pour traumatisme / 100 000 hab. (indicateur principal)" %}
  {% assign t_ira = "Passages aux urgences pour infection respiratoire aiguë / 100 000 hab." %}
  {% assign t_trend_8w = "Évolution, traumatisme vs respiratoire (8 semaines)" %}
  {% assign t_trauma_line = "Traumatisme" %}
  {% assign t_ira_line = "Respiratoire" %}
  {% assign t_by_age = "Taux de traumatisme par tranche d'âge / 100 000 hab." %}
  {% assign t_age_0_14 = "0–14 ans" %}
  {% assign t_age_15_64 = "15–64 ans" %}
  {% assign t_age_65 = "65 ans et +" %}
  {% assign t_other_path = "Autres pathologies, taux de passages / 100 000 hab." %}
  {% assign t_path_covid = "COVID-19" %}
  {% assign t_path_gastro = "Gastro-entérite" %}
  {% assign t_path_bronchite = "Bronchite" %}
  {% assign t_path_pneumopathie = "Pneumopathie" %}
  {% assign t_path_orl = "Pathologies ORL" %}
  {% assign t_path_asthme = "Asthme" %}
  {% assign t_path_allergie = "Allergie" %}
  {% assign t_disclaimer = "Approximation : il n'existe pas de taux d'occupation de lits en open data en France. Cet indicateur repose sur les passages aux urgences (réseau OSCOUR / SurSaUD, Santé publique France, portail Odissé), pas sur la capacité réelle des lits." %}
  {% assign t_source_fr = "Source : Santé publique France, portail open data Odissé (réseau SurSaUD / OSCOUR)" %}
{% endif %}

{% assign arrow_up = "▲" %}
{% assign arrow_down = "▼" %}
{% assign arrow_stable = "–" %}

{% if country == "us" %}
  {% assign s = us[us_state] %}
  {% case s.level %}
    {% when "low" %}{% assign t_level = t_level_low %}
    {% when "moderate" %}{% assign t_level = t_level_moderate %}
    {% when "high" %}{% assign t_level = t_level_high %}
  {% endcase %}
  {% assign deltaSign = "+" %}
  {% if s.deltaPts < 0 %}{% assign deltaSign = "" %}{% endif %}

  <div class="layout">
    <div class="columns">
      <div class="column">
        <span class="title title--small">{{ t_title_us }}{{ s.name }}</span>
        <span class="label">{{ t_week_ending }} {{ s.weekEnding }}</span>

        <div class="value value--xlarge">{{ s.pctBedsOccupied }}%</div>
        <span class="label">{{ t_beds_occ }} — {{ t_level_word }} {{ t_level }} ({{ deltaSign }}{{ s.deltaPts }} pts {{ t_vs_last_week }})</span>

        {% assign barWidth = s.pctBedsOccupied | times: 6 %}
        <svg width="600" height="34" viewBox="0 0 600 34">
          <rect x="0" y="6" width="600" height="22" fill="none" stroke="black" stroke-width="2"/>
          <rect x="0" y="6" width="{{ barWidth }}" height="22" fill="black"/>
          <line x1="420" y1="0" x2="420" y2="34" stroke="black" stroke-width="1" stroke-dasharray="2,2"/>
          <line x1="510" y1="0" x2="510" y2="34" stroke="black" stroke-width="1" stroke-dasharray="2,2"/>
        </svg>
        <span class="description">{{ t_scale }}</span>

        <table style="margin-top:8px">
          <tr><td>{{ t_adult }}</td><td>{{ s.pctBedsOccupiedAdult }}%</td><td>{{ s.pctIcuOccupiedAdult }}% ICU</td></tr>
          <tr><td>{{ t_ped }}</td><td>{{ s.pctBedsOccupiedPed }}%</td><td>{{ s.pctIcuOccupiedPed }}% ICU</td></tr>
        </table>

        <span class="label" style="margin-top:8px">{{ t_ed_visits }}</span>
        <table>
          <tr>
            <td>COVID-19</td><td>{{ s.nssp.pctVisitsCovid }}%</td>
            <td>{% case s.nssp.trendCovid %}{% when "up" %}{{ arrow_up }}{% when "down" %}{{ arrow_down }}{% else %}{{ arrow_stable }}{% endcase %}</td>
          </tr>
          <tr>
            <td>{{ t_flu }}</td><td>{{ s.nssp.pctVisitsFlu }}%</td>
            <td>{% case s.nssp.trendFlu %}{% when "up" %}{{ arrow_up }}{% when "down" %}{{ arrow_down }}{% else %}{{ arrow_stable }}{% endcase %}</td>
          </tr>
          <tr>
            <td>RSV</td><td>{{ s.nssp.pctVisitsRsv }}%</td>
            <td>{% case s.nssp.trendRsv %}{% when "up" %}{{ arrow_up }}{% when "down" %}{{ arrow_down }}{% else %}{{ arrow_stable }}{% endcase %}</td>
          </tr>
        </table>
        <span class="description">{{ t_ed_note }} · {{ t_source_nssp }}</span>
      </div>

      <div class="column">
        <span class="label">{{ t_icu }}</span>
        <span class="value value--large">{{ s.pctIcuOccupied }}%</span>

        <span class="label">{{ t_new_adm }}</span>
        <table>
          <tr><td>COVID-19</td><td>{{ s.newAdmCovid }}</td><td>{{ s.newAdmCovidPer100k }}</td></tr>
          <tr><td>{{ t_flu }}</td><td>{{ s.newAdmFlu }}</td><td>{{ s.newAdmFluPer100k }}</td></tr>
          <tr><td>RSV</td><td>{{ s.newAdmRsv }}</td><td>{{ s.newAdmRsvPer100k }}</td></tr>
        </table>

        <span class="label" style="margin-top:8px">{{ t_coverage }}</span>
        <span class="value value--medium">{{ s.reportingCoveragePct }}%</span>
        <span class="description">{{ s.reportingHospitals }} {{ t_hospitals }}</span>
      </div>
    </div>

    <div class="row">
      <span class="label">{{ t_trend_beds }}</span>
      <svg width="760" height="90" viewBox="0 0 760 90">
        {% assign ptsInpt = "" %}
        {% assign ptsIcu = "" %}
        {% for h in s.history %}
          {% assign x = forloop.index0 | times: 108 %}
          {% assign yI = 90 | minus: h.pctInpt %}
          {% assign yC = 90 | minus: h.pctIcu %}
          {% assign ptI = x | append: "," | append: yI %}
          {% assign ptC = x | append: "," | append: yC %}
          {% assign ptsInpt = ptsInpt | append: ptI | append: " " %}
          {% assign ptsIcu = ptsIcu | append: ptC | append: " " %}
        {% endfor %}
        <polyline points="{{ ptsInpt }}" fill="none" stroke="black" stroke-width="3"/>
        <polyline points="{{ ptsIcu }}" fill="none" stroke="black" stroke-width="1.5" stroke-dasharray="5,3"/>
      </svg>
      <span class="description">— {{ t_inpatient }} · ┅ ICU</span>
    </div>

    <div class="footer">
      <span class="description">{{ t_source_us }}</span>
    </div>
  </div>

{% else %}
  {% assign r = fr[fr_region] %}
  {% case r.trend %}
    {% when "up" %}{% assign t_trend = t_trend_up %}
    {% when "down" %}{% assign t_trend = t_trend_down %}
    {% else %}{% assign t_trend = t_trend_stable %}
  {% endcase %}
  {% assign deltaSignFr = "+" %}
  {% if r.deltaPct < 0 %}{% assign deltaSignFr = "" %}{% endif %}

  <div class="layout">
    <div class="columns">
      <div class="column">
        <span class="title title--small">{{ t_title_fr }}{{ r.name }}</span>
        <span class="label">{{ t_week_ending }} {{ r.weekEnding }} · {{ t_trend_label }} : {{ t_trend }} ({{ deltaSignFr }}{{ r.deltaPct }}% {{ t_vs_last_week }})</span>

        <div class="value value--large">{{ r.tauxTraumaSAU | round }}</div>
        <span class="label">{{ t_trauma }}</span>

        <div class="value value--medium">{{ r.tauxIraSAU | round }}</div>
        <span class="label">{{ t_ira }}</span>

        <span class="label" style="margin-top:8px">{{ t_by_age }}</span>
        <table>
          <tr><td>{{ t_age_0_14 }}</td><td>{{ r.byAgeTrauma["0-14"] | round }}</td></tr>
          <tr><td>{{ t_age_15_64 }}</td><td>{{ r.byAgeTrauma["15-64"] | round }}</td></tr>
          <tr><td>{{ t_age_65 }}</td><td>{{ r.byAgeTrauma["65+"] | round }}</td></tr>
        </table>
      </div>

      <div class="column">
        <span class="label">{{ t_other_path }}</span>
        <table>
          <tr>
            <td>{{ t_path_covid }}</td><td>{{ r.pathologies.covid.rate | round }}</td>
            <td>{% case r.pathologies.covid.trend %}{% when "up" %}{{ arrow_up }}{% when "down" %}{{ arrow_down }}{% else %}{{ arrow_stable }}{% endcase %}</td>
          </tr>
          <tr>
            <td>{{ t_path_gastro }}</td><td>{{ r.pathologies.gastro.rate | round }}</td>
            <td>{% case r.pathologies.gastro.trend %}{% when "up" %}{{ arrow_up }}{% when "down" %}{{ arrow_down }}{% else %}{{ arrow_stable }}{% endcase %}</td>
          </tr>
          <tr>
            <td>{{ t_path_bronchite }}</td><td>{{ r.pathologies.bronchite.rate | round }}</td>
            <td>{% case r.pathologies.bronchite.trend %}{% when "up" %}{{ arrow_up }}{% when "down" %}{{ arrow_down }}{% else %}{{ arrow_stable }}{% endcase %}</td>
          </tr>
          <tr>
            <td>{{ t_path_pneumopathie }}</td><td>{{ r.pathologies.pneumopathie.rate | round }}</td>
            <td>{% case r.pathologies.pneumopathie.trend %}{% when "up" %}{{ arrow_up }}{% when "down" %}{{ arrow_down }}{% else %}{{ arrow_stable }}{% endcase %}</td>
          </tr>
          <tr>
            <td>{{ t_path_orl }}</td><td>{{ r.pathologies.orl.rate | round }}</td>
            <td>{% case r.pathologies.orl.trend %}{% when "up" %}{{ arrow_up }}{% when "down" %}{{ arrow_down }}{% else %}{{ arrow_stable }}{% endcase %}</td>
          </tr>
          <tr>
            <td>{{ t_path_asthme }}</td><td>{{ r.pathologies.asthme.rate | round }}</td>
            <td>{% case r.pathologies.asthme.trend %}{% when "up" %}{{ arrow_up }}{% when "down" %}{{ arrow_down }}{% else %}{{ arrow_stable }}{% endcase %}</td>
          </tr>
          <tr>
            <td>{{ t_path_allergie }}</td><td>{{ r.pathologies.allergie.rate | round }}</td>
            <td>{% case r.pathologies.allergie.trend %}{% when "up" %}{{ arrow_up }}{% when "down" %}{{ arrow_down }}{% else %}{{ arrow_stable }}{% endcase %}</td>
          </tr>
        </table>
      </div>
    </div>

    <div class="row">
      <span class="label">{{ t_trend_8w }}</span>
      <svg width="760" height="90" viewBox="0 0 760 90">
        {% assign ptsT = "" %}
        {% assign ptsI = "" %}
        {% for h in r.history %}
          {% assign xT = forloop.index0 | times: 108 %}
          {% assign yT = h.trauma | divided_by: 400 %}
          {% assign yT = 90 | minus: yT %}
          {% assign yIr = h.ira | divided_by: 25 %}
          {% assign yIr = 90 | minus: yIr %}
          {% assign ptT = xT | append: "," | append: yT %}
          {% assign ptI = xT | append: "," | append: yIr %}
          {% assign ptsT = ptsT | append: ptT | append: " " %}
          {% assign ptsI = ptsI | append: ptI | append: " " %}
        {% endfor %}
        <polyline points="{{ ptsT }}" fill="none" stroke="black" stroke-width="3"/>
        <polyline points="{{ ptsI }}" fill="none" stroke="black" stroke-width="1.5" stroke-dasharray="5,3"/>
      </svg>
      <span class="description">— {{ t_trauma_line }} · ┅ {{ t_ira_line }}</span>
    </div>

    <div class="footer">
      <span class="description">{{ t_source_fr }}. {{ t_disclaimer }}</span>
    </div>
  </div>
{% endif %}
